# Agentic OS — Environment Variables
# Copy to .env.local for local overrides. Never commit .env.local.

# Server bind / port
PORT=3017
AGENTIC_HOST=127.0.0.1

# Data source: "mock" uses fixture data, "live" reads real local files
DATA_SOURCE=live

# Obsidian vault path (absolute). Required for Obsidian agent page + sidebar dot.
# Example (Ubuntu): /home/chris/vaults/Refuelr
# Example (macOS):  /Users/chris/vaults/Refuelr
VAULT_PATH=

# Hermes home directory. Leave blank to use default (~/.hermes). Drives the
# Hermes agent page (jobs, skills, memory, synthesized sessions).
HERMES_HOME=

# Hermes kanban SQLite database path. Leave blank to use default ($HERMES_HOME/kanban.db
# → ~/.hermes/kanban.db).
HERMES_KANBAN_DB=

# Hermes kanban board slug. Used only when HERMES_KANBAN_DB is blank. Resolution
# order is HERMES_KANBAN_DB -> HERMES_KANBAN_BOARD -> ~/.hermes/kanban/current
# -> default board -> legacy ~/.hermes/kanban.db.
HERMES_KANBAN_BOARD=

# Hermes chat history SQLite database (sessions + messages). Leave blank to use
# default ($HERMES_HOME/state.db → ~/.hermes/state.db). Drives the Hermes
# Sessions rail + transcripts.
HERMES_STATE_DB=

# Optional GitHub token for repository metadata. Without it, repos still appear
# from local git workspaces, but private GitHub metadata may be unavailable.
GITHUB_TOKEN=

# Disable the unused SSE exec route by default. Set to 1 only if you explicitly
# need /api/agents/[agent]/run on a trusted loopback host.
AGENTIC_ENABLE_RUN_ROUTE=0

# Additional allowed cwd roots for PTY sessions (colon-separated on Linux/macOS,
# semicolon-separated on Windows). Keep this explicit and narrow; the server
# always allows its own working directory and nothing broader by default.
# Example: /home/chris/Development:/srv/worktrees
AGENTIC_ALLOWED_ROOTS=

# Narrower execution roots for live PTY sessions. If blank, PTY sessions can
# start only in the app directory. Prefer repo/worktree roots, not the home dir.
# Example: /home/chris/refuelr:/home/chris/agentic-os
AGENTIC_PTY_ALLOWED_ROOTS=
